# wshell configuration
# Copy this to .env or set these environment variables before starting.

# Server
PORT=3000
HOST=127.0.0.1        # Set to 0.0.0.0 for IPv4, :: for IPv6 remote access

# Authentication
WSHELL_USERNAME=admin  # Login username
WSHELL_PASSWORD=admin  # Login password (CHANGE THIS for public deployments!)

# Shell configuration
WSHELL_SHELL=/bin/zsh   # Shell to spawn (default: $SHELL or /bin/zsh)
WSHELL_SCROLLBACK=10000  # Max lines of scrollback per session
WSHELL_SESSION_TTL_MINUTES=30   # Idle detached session timeout
WSHELL_EXIT_TTL_MINUTES=5       # Exited session cleanup delay
